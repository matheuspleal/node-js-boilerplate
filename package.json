{
  "name": "node-js-boilerplate",
  "version": "1.0.0",
  "description": "Node.js Boilerplate developed with TypeScript, using Clean Architecture, Domain-Driven Design (DDD) and Test Driven Development (TDD)",
  "author": {
    "name": "Matheus Pereira Leal",
    "email": "contact@matheuspleal.com"
  },
  "license": "ISC",
  "keywords": [
    "nodejs",
    "typescript",
    "clean-architecture",
    "domain-driven-design",
    "ddd",
    "test-driven-development",
    "tdd",
    "solid",
    "design-patterns",
    "boilerplate",
    "restapi",
    "graphql"
  ],
  "main": "dist/main/server.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "check": "pnpm exec npm-check -s -u",
    "lint": "eslint src",
    "lint:fix": "pnpm run lint -- --fix",
    "migrate:dev": "pnpm exec prisma migrate dev",
    "migrate:prod": "pnpm exec prisma migrate deploy",
    "node:js": "node --env-file=.env",
    "node:ts": "node --env-file=.env --import=tsx",
    "prepare": "husky",
    "prisma:studio": "pnpm exec prisma studio",
    "setup:test": "docker-compose up database -d",
    "start": "pnpm run migrate:prod && node -- dist/main/server.js",
    "start:dev": "pnpm run migrate:dev && pnpm run node:ts -- --inspect --watch src/main/server.ts",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --config ./vitest-ci.config.ts --coverage",
    "test:e2e": "pnpm run setup:test && vitest run --config ./vitest-e2e.config.ts",
    "test:e2e:watch": "pnpm run setup:test && vitest --config ./vitest-e2e.config.ts",
    "test:staged": "vitest related --run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --passWithNoTests"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@eslint/js": "9.39.2",
    "@faker-js/faker": "10.3.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.3.3",
    "@types/pg": "8.18.0",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "coveralls": "3.1.1",
    "dotenv": "17.3.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-vitest-globals": "1.5.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "kleur": "4.1.5",
    "lint-staged": "16.3.1",
    "npm-check": "6.0.1",
    "openapi-types": "12.1.3",
    "prisma": "7.4.2",
    "semantic-release": "25.0.3",
    "supertest": "7.2.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18",
    "vitest-mock-extended": "3.1.0"
  },
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@as-integrations/fastify": "3.1.0",
    "@fastify/cors": "11.2.0",
    "@fastify/swagger": "9.7.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@scalar/fastify-api-reference": "1.46.3",
    "@scalar/themes": "0.14.3",
    "bcryptjs": "3.0.3",
    "fastify": "5.7.4",
    "graphql": "16.13.0",
    "jsonwebtoken": "9.0.3",
    "pg": "8.19.0",
    "zx": "8.8.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.9.5"
  },
  "engines": {
    "node": "24.14.1"
  },
  "packageManager": "pnpm@10.26.1"
}
