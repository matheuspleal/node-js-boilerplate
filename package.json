{
  "name": "node-js-boilerplate",
  "version": "1.0.2",
  "description": "Node.js Boilerplate developed with TypeScript, using Clean Architecture, Domain-Driven Design (DDD) and Test Driven Development (TDD)",
  "author": {
    "name": "Matheus Pereira Leal",
    "email": "contact@matheuspleal.com"
  },
  "license": "ISC",
  "keywords": [
    "nodejs",
    "typescript",
    "clean-architecture",
    "domain-driven-design",
    "ddd",
    "test-driven-development",
    "tdd",
    "solid",
    "design-patterns",
    "boilerplate",
    "restapi",
    "graphql"
  ],
  "main": "dist/main/server.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "check": "npx npm-check -s -u",
    "lint": "eslint src",
    "lint:fix": "npm run lint -- --fix",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:prod": "npx prisma migrate deploy",
    "node:js": "node --env-file=.env",
    "node:ts": "node --env-file=.env --import=tsx",
    "prepare": "husky",
    "prisma:studio": "npx prisma studio",
    "setup:test": "docker-compose up database -d",
    "start": "npm run migrate:prod && npm run node:js -- dist/main/server.js",
    "start:dev": "npm run migrate:dev && npm run node:ts -- --inspect --watch src/main/server.ts",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --config ./vitest.config.ci.ts --coverage",
    "test:e2e": "npm run setup:test && vitest run --config ./vitest.config.e2e.ts",
    "test:e2e:watch": "npm run setup:test && vitest --config ./vitest.config.e2e.ts",
    "test:staged": "vitest related --run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --passWithNoTests",
    "wizard": "npm run node:ts -- ./scripts/wizard.ts",
    "wizard:logs": "npm run node:ts -- ./scripts/wizard.ts --logs"
  },
  "devDependencies": {
    "@commitlint/cli": "20.1.0",
    "@commitlint/config-conventional": "20.0.0",
    "@eslint/js": "9.38.0",
    "@faker-js/faker": "10.1.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.0",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/bcryptjs": "3.0.0",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.8.1",
    "@types/pg": "8.15.5",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/parser": "8.46.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "coveralls": "3.1.1",
    "dotenv": "17.2.3",
    "eslint": "9.38.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-vitest-globals": "1.5.0",
    "globals": "16.4.0",
    "husky": "9.1.7",
    "kleur": "4.1.5",
    "lint-staged": "16.2.4",
    "npm-check": "6.0.1",
    "openapi-types": "12.1.3",
    "prisma": "6.17.1",
    "semantic-release": "25.0.0",
    "supertest": "7.1.4",
    "tsup": "8.5.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4",
    "vitest-mock-extended": "3.1.0"
  },
  "dependencies": {
    "@apollo/server": "5.0.0",
    "@as-integrations/fastify": "3.1.0",
    "@fastify/cors": "11.1.0",
    "@fastify/swagger": "9.5.2",
    "@prisma/client": "6.17.1",
    "@scalar/fastify-api-reference": "1.38.1",
    "@scalar/themes": "0.13.22",
    "bcryptjs": "3.0.2",
    "fastify": "5.6.1",
    "graphql": "16.11.0",
    "jsonwebtoken": "9.0.2",
    "pg": "8.16.3",
    "zx": "8.8.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.9.5"
  },
  "engines": {
    "node": "22.20.0"
  }
}
